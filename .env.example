# ──────────────────────────────────────────
# CONFIGURACIÓN DEL BOT DE WHATSAPP
# Copia este archivo como .env y llena los valores
# ──────────────────────────────────────────

# Claude / Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx

# Tu número real (donde recibirás notificaciones de créditos)
# Formato: código de país + número, SIN + ni espacios
# Ejemplo Colombia: 573001234567
MI_NUMERO_REAL=573001234567

# Supabase (opcional pero recomendado para ver datos desde el celular)
# Consíguelos en: https://supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL del servidor Node.js (no cambiar si es local)
BOT_SERVER_URL=http://localhost:3000
